# ===== Compose runtime env =====
# Copy to .env.compose and adjust before production deploy

# Frontend host port
FRONTEND_PORT=5174

# Backend
APP_NAME=AiOps API
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRE_MINUTES=120

# Postgres
POSTGRES_DB=aiops
POSTGRES_USER=aiops
POSTGRES_PASSWORD=replace-with-strong-password

# Redis
REDIS_APPENDONLY=yes
